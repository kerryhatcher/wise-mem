# Copy to `.env` (gitignored) and adjust. Defaults match the local container
# stack in compose.yaml (`just up`).

# Async SQLAlchemy DSN. Note the +asyncpg driver. For the local container stack:
DATABASE_URL=postgresql+asyncpg://wise-mem:wise-mem-dev@localhost:5433/wise-mem
# Remote example (the thor server): postgresql+asyncpg://wise-mem:<pass>@thor.tailb56d83.ts.net:5432/wise-mem

# Log all SQL emitted by the engine (handy while developing).
DB_ECHO=false

# Ollama for embeddings (nomic-embed-text, 768-dim). Defaults to the host daemon.
# OLLAMA_HOST=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text

# Phase 2 — Memgraph derived graph projection. Not yet read by config.py; the
# container is started by `just up` so it's ready when Phase 2 wiring lands.
# MEMGRAPH_BOLT_URL=bolt://localhost:7687
